# --- Data & Models (IMPORTANT: Storage heavy) ---
# Ignore everything in data/ except the .gitkeep file
data/*
!data/.gitkeep
# Also ignore data files found anywhere in the repo
sample_covers/
*.faiss
*.npz
*.parquet
*.zip
*.tar.gz
*.csv
*.pt
*.pkl
*.json
# Keep important JSONs if they are config, but generally data/profiles have them
!package.json
!package-lock.json
!tsconfig.json
!composer.json
!manifest.json
!profiling/*.json

# --- Logs, Reports & Temp ---
*.log
*.txt
rebuild.log
inspect_output*.txt
smoke_test_output.txt
tmp/
temp/
*.tmp
*.temp
profiling/benchmark_results_*.txt
profiling/clip_audit_*.txt
profiling/vi_search_audit_*.txt

